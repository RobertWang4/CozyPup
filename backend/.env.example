DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/cozypup
DEFAULT_MODEL=openai/qwen3.5-plus-2026-02-15
EMERGENCY_MODEL=openai/kimi-k2.5
MODEL_API_BASE=https://api.shubiaobiao.cn/v1
MODEL_API_KEY=
GOOGLE_PLACES_API_KEY=
JWT_SECRET=change-me-in-production
JWT_ACCESS_EXPIRE_MINUTES=60
JWT_REFRESH_EXPIRE_DAYS=30

# APNs Push Notifications (optional — runs in simulated mode without these)
APNS_KEY_PATH=          # Path to .p8 key file from Apple Developer
APNS_KEY_ID=            # 10-char Key ID
APNS_TEAM_ID=           # Apple Developer Team ID
APNS_BUNDLE_ID=com.cozypup.app
APNS_USE_SANDBOX=true
